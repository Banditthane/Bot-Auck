const fs = require("fs");
const path = require("path");

module.exports = function registerEvents(client, services) {
  const eventsBasePath = path.resolve(
    __dirname,
    "..",
    "interfaces",
    "discord",
    "events"
  );

  const folders = fs.readdirSync(eventsBasePath);

  for (const folder of folders) {
    const folderPath = path.join(eventsBasePath, folder);

    if (!fs.statSync(folderPath).isDirectory()) continue;

    const files = fs
      .readdirSync(folderPath)
      .filter((file) => file.endsWith(".js"));

    for (const file of files) {
      const event = require(path.join(folderPath, file));

      if (event.once) {
        client.once(event.name, (...args) =>
          event.execute(...args, { client, services })
        );
      } else {
        client.on(event.name, (...args) =>
          event.execute(...args, { client, services })
        );
      }
    }
  }
};